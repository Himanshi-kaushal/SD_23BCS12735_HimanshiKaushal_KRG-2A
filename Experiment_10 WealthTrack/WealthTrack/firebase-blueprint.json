{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User specific settings and metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique identifier" },
        "displayName": { "type": "string", "description": "Display name of the user" },
        "email": { "type": "string", "format": "email" },
        "currency": { "type": "string", "enum": ["USD", "EUR", "INR", "GBP"], "description": "Preferred currency" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "currency", "createdAt", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The owner of this transaction" },
        "amount": { "type": "number", "description": "The transaction amount" },
        "category": { "type": "string", "description": "Category (e.g., Food, Rent, Salary)" },
        "description": { "type": "string", "description": "Short description of the transaction" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "date": { "type": "string", "format": "date-time", "description": "When the transaction occurred" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "category", "type", "date", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and settings"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User transactions"
    }
  }
}
