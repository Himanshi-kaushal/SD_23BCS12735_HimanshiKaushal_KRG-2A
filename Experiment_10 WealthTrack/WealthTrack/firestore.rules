rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Globals
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid &&
               data.email == request.auth.token.email &&
               data.displayName is string && data.displayName.size() <= 100 &&
               data.currency in ['USD', 'EUR', 'INR', 'GBP'] &&
               data.createdAt == request.time &&
               data.updatedAt == request.time;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) &&
                       incoming().updatedAt == request.time &&
                       incoming().uid == existing().uid &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().email == existing().email &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'currency', 'updatedAt']);
    }

    // 2. Transactions
    match /transactions/{transactionId} {
      function isValidTransaction(data) {
        return data.userId == request.auth.uid &&
               data.amount is number && data.amount > 0 &&
               data.category is string && data.category.size() <= 64 &&
               data.description is string && data.description.size() <= 256 &&
               data.type in ['income', 'expense'] &&
               data.date is timestamp &&
               data.createdAt == request.time &&
               data.updatedAt == request.time;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid && isValidId(transactionId);
      
      allow create: if isSignedIn() && 
                       isValidTransaction(incoming()) && 
                       isValidId(transactionId);

      allow update: if isSignedIn() && 
                       resource.data.userId == request.auth.uid &&
                       isValidTransaction(incoming()) &&
                       incoming().userId == existing().userId &&
                       incoming().createdAt == existing().createdAt &&
                       (
                         // Action: Edit details
                         incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'category', 'description', 'type', 'date', 'updatedAt'])
                       );
      
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
